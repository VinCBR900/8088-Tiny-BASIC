   813 00000473 29D9                            sub cx,bx                ; bytes to slide down
   814 00000475 5F                              pop di                   ; DI = destination
   815 00000476 89DE                            mov si,bx
   816 00000478 F3A4                            rep movsb                ; forward move for deletion
   817 0000047A C3                              ret
