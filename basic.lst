   729                                          ;------------------------------------------------------------
   730                                          ; EDITLN
   731                                          ; Function : Replace/insert/delete packed program line.
   732                                          ; Inputs   : AX = line number, SI = tokenized text + CR.
   733                                          ; Outputs  : Program image updated in RAM.
   734                                          ; Clobbers : AX,BX,CX,DX,SI,DI,BP.
   735                                          ;------------------------------------------------------------
   736                                  editln:
   737 000003F4 50                              push ax                  ; Save line number
   738 000003F5 E80AFE                          call spaces
   739 000003F8 5A                              pop dx                   ; DX = line number
   740 000003F9 89F3                            mov bx,si                ; BX = line text pointer
   741 000003FB B90100                          mov cx,1
   742                                  editln_len:
   743 000003FE 803C0D                          cmp byte [si],0x0d
   744 00000401 7404                            je editln_len_done
   745 00000403 46                              inc si
   746 00000404 41                              inc cx
   747 00000405 EBF7                            jmp editln_len
   748                                  editln_len_done:
   749 00000407 89D0                            mov ax,dx
   750 00000409 E8B1FF                          call find_line
   751 0000040C 3915                            cmp word [di],dx
   752 0000040E 7503                            jne editln_no_existing
   753 00000410 E85200                          call deline              ; delete existing line at DI
   754                                  editln_no_existing:
   755 00000413 803F0D                          cmp byte [bx],0x0d
   756 00000416 740A                            je editln_done           ; pure line number => deletion
   757 00000418 89DE                            mov si,bx
   758 0000041A 89D0                            mov ax,dx
   759 0000041C 83C102                          add cx,2                 ; line number + text (CR already counted)
   760 0000041F E80100                          call insline
   761                                  editln_done:
   762 00000422 C3                              ret
   763                                  
   764                                          ; Insert new line AX at DI, with text at SI and total size in CX.
   765                                  insline:
   766 00000423 50                              push ax
   767 00000424 51                              push cx
   768 00000425 56                              push si
   769 00000426 57                              push di
   770 00000427 E8B9FF                          call find_program_end
   771 0000042A 89FD                            mov bp,di                ; BP = end marker pointer
   772 0000042C 5F                              pop di                   ; DI = insertion pointer
   773 0000042D 5E                              pop si                   ; SI = text pointer
   774 0000042E 59                              pop cx                   ; CX = new total size
   775 0000042F 58                              pop ax                   ; AX = line number
   776 00000430 89EB                            mov bx,bp
   777 00000432 83C302                          add bx,2
   778 00000435 01CB                            add bx,cx
   779 00000437 81FB001E                        cmp bx,PROGRAM_TOP
   780 0000043B 7725                            ja insline_oom
   781 0000043D 89EB                            mov bx,bp
   782 0000043F 83C302                          add bx,2                 ; include zero marker
   783 00000442 29FB                            sub bx,di                ; bytes to move
