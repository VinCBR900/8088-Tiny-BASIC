   785 00000446 FD                              std
   786 00000447 8D71FF                          lea si,[di+bx-1]
   787 0000044A 01DF                            add di,bx
   788 0000044C 01D7                            add di,dx
   789 0000044E 4F                              dec di
   790 0000044F 89D9                            mov cx,bx
   791 00000451 F3A4                            rep movsb                ; top-down move for insertion
   792 00000453 FC                              cld
   793 00000454 29DF                            sub di,bx
   794 00000456 8905                            mov [di],ax
   795 00000458 83C702                          add di,2
   796                                  insline_copy:
   797 0000045B AC                              lodsb
   798 0000045C AA                              stosb
   799 0000045D 3C0D                            cmp al,0x0d
   800 0000045F 75FA                            jne insline_copy
   801 00000461 C3                              ret
   802                                  insline_oom:
   803 00000462 E928FC                          jmp error
   804                                  
   805                                  deline:
   806                                          ; Delete existing line at DI
   807 00000465 57                              push di
