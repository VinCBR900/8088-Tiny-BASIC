     1                                          ; TINY BASIC 8086 COM EDITION
     2                                          ; Original author: Oscar Toledo G.
     3                                          ; Website: http://nanochess.org/
     4                                          ;
     5                                          ; Version 2.1.0 (2026-04-08)
     6                                          ; Changes since original:
     7                                          ; - COM-only target, no boot-sector mode.
     8                                          ; - Packed editable program lines (EDITLN/INSLINE/DELINE).
     9                                          ; - 4KB simulated RAM window at 0x1000..0x1FFF.
    10                                          ; - Tokenized keywords and signed 16-bit numeric literals.
    11                                          ; - FREE command and startup free-RAM sign-on.
    12                                          ; - CHR$ support in PRINT.
    13                                  
    14                                          cpu 8086
    15                                  
    16                                          org 0x0100
    17                                  
    18                                  STACK_TOP:   equ 0x1fff
    19                                  PROGRAM_TOP: equ 0x1e00
    20                                  RAM_END:     equ 0x2000
    21                                  
    22                                  tok_new:    equ 0x80
    23                                  tok_list:   equ 0x81
    24                                  tok_run:    equ 0x82
    25                                  tok_print:  equ 0x83
    26                                  tok_input:  equ 0x84
    27                                  tok_if:     equ 0x85
    28                                  tok_goto:   equ 0x86
    29                                  tok_system: equ 0x87
    30                                  tok_rnd:    equ 0x88
    31                                  tok_num:    equ 0x89
    32                                  tok_free:   equ 0x8a
    33                                  tok_chr:    equ 0x8b
    34                                  
    35                                  start:
    36 00000000 0E                              push cs
    37 00000001 1F                              pop ds
    38 00000002 0E                              push cs
    39 00000003 07                              pop es
    40 00000004 0E                              push cs
    41 00000005 17                              pop ss
    42 00000006 FC                              cld             ; Clear Direction flag
    43 00000007 BE[BB04]                        mov si,signon
    44 0000000A E8F800                          call print_z
    45 0000000D E8E700                          call free_bytes
    46 00000010 E8F501                          call output_number
    47 00000013 E89803                          call new_line
    48                                  
    49                                          ;
    50                                          ; Main loop
    51                                          ;
    52                                  main_loop:
    53 00000016 BCFF1F                          mov sp,STACK_TOP
    54 00000019 B8[1600]                        mov ax,main_loop
    55 0000001C 50                              push ax
    56 0000001D B03E                            mov al,'>'      ; Show prompt
    57 0000001F E85602                          call input_line ; Accept line
    58 00000022 E8F801                          call input_number       ; Get number
    59 00000025 09C0                            or ax,ax        ; No number or zero?
    60 00000027 7411                            je statement    ; Yes, jump
    61 00000029 E88902                          call tokenize_line
    62 0000002C E8C503                          call editln
    63 0000002F C3                              ret
    64                                  
    65                                          ;
    66                                          ; Handle 'if' statement
    67                                          ;
    68                                  if_statement:
    69 00000030 E83F01                          call expr       ; Process expression
    70 00000033 09C0                            or ax,ax        ; Is it zero?
    71 00000035 7503E9B300                      je f6           ; Yes, return (ignore if)
    72                                  statement:
    73 0000003A E8C501                          call spaces     ; Avoid spaces
    74 0000003D 803C0D                          cmp byte [si],0x0d  ; Empty line?
    75 00000040 7503E9A800                      je f6           ; Yes, return
    76 00000045 803C80                          cmp byte [si],tok_new
    77 00000048 721A                            jb statement_text
    78 0000004A AC                              lodsb
    79 0000004B 3C8A                            cmp al,tok_free
    80 0000004D 7503E99C00                      je free_statement
    81 00000052 2C80                            sub al,tok_new
    82 00000054 3C07                            cmp al,7
    83 00000056 7735                            ja error
    84 00000058 98                              cbw
    85 00000059 01C0                            add ax,ax
    86 0000005B 89C3                            mov bx,ax
    87 0000005D E8A201                          call spaces
    88 00000060 FFA7[9900]                      jmp word [statement_tokens+bx]
    89                                  statement_text:
    90 00000064 BF[7B04]                        mov di,statements   ; Point to statements list
    91 00000067 8A05                    f5:     mov al,[di]     ; Read length of the string
    92 00000069 47                              inc di          ; Avoid length byte
    93 0000006A 98                              cbw             ; Make AH zero
    94 0000006B 48                              dec ax          ; Is it zero?
    95 0000006C 7413                            je f4           ; Yes, jump
    96 0000006E 91                              xchg ax,cx
    97 0000006F 56                              push si         ; Save current position
    98 00000070 F3A6                    f16:    rep cmpsb       ; Compare statement
    99 00000072 7506                            jne f3          ; Equal? No, jump
   100 00000074 58                              pop ax
   101 00000075 E88A01                          call spaces     ; Avoid spaces
   102 00000078 FF25                            jmp word [di]   ; Jump to process statement
   103                                  
   104 0000007A 01CF                    f3:     add di,cx       ; Advance the list pointer
   105 0000007C 47                              inc di          ; Avoid the address
   106 0000007D 47                              inc di
   107 0000007E 5E                              pop si
   108 0000007F EBE6                            jmp f5          ; Compare another statement
   109                                  
   110 00000081 E87201                  f4:     call get_variable       ; Try variable
   111 00000084 50                              push ax         ; Save address
   112 00000085 AC                              lodsb           ; Read a line letter
   113 00000086 3C3D                            cmp al,'='      ; Is it assignment '=' ?
   114 00000088 7503E9DF00                      je assignment   ; Yes, jump to assignment.
   115                                  
   116                                          ;
   117                                          ; An error happened
   118                                          ;
   119                                  error:
   120 0000008D BE[9500]                        mov si,error_message
   121 00000090 E8D802                          call print_2    ; Show error message
   122 00000093 EB81                            jmp main_loop   ; Exit to main loop
   123                                  
   124                                  error_message:
   125 00000095 4023210D                        db "@#!",0x0d   ; Guess the words :P
   126                                  statement_tokens:
   127 00000099 [0000]                          dw start
   128 0000009B [D400]                          dw list_statement
   129 0000009D [4E02]                          dw run_statement
   130 0000009F [6203]                          dw print_statement
   131 000000A1 [6301]                          dw input_statement
   132 000000A3 [3000]                          dw if_statement
   133 000000A5 [3502]                          dw goto_statement
   134 000000A7 [3302]                          dw system_statement
   135                                  
   136                                  kw_table:
   137 000000A9 6E65F7                          db 'n','e','w'+0x80
   138 000000AC 6C6973F4                        db 'l','i','s','t'+0x80
   139 000000B0 7275EE                          db 'r','u','n'+0x80
   140 000000B3 7072696EF4                      db 'p','r','i','n','t'+0x80
   141 000000B8 696E7075F4                      db 'i','n','p','u','t'+0x80
   142 000000BD 69E6                            db 'i','f'+0x80
   143 000000BF 676F74EF                        db 'g','o','t','o'+0x80
   144 000000C3 7379737465ED                    db 's','y','s','t','e','m'+0x80
   145 000000C9 726EE4                          db 'r','n','d'+0x80
   146 000000CC 667265E5                        db 'f','r','e','e'+0x80
   147 000000D0 636872A4                        db 'c','h','r','$'+0x80
