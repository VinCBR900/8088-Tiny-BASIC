   149                                          ;
   150                                          ; Handle 'list' statement
   151                                          ;
   152                                  list_statement:
   153 000000D4 BE[7C10]                        mov si,program
   154 000000D7 8B04                    f29:    mov ax,[si]
   155 000000D9 09C0                            or ax,ax
   156 000000DB 7410                            je f6
   157 000000DD E82801                          call output_number ; Show line number
   158 000000E0 83C602                          add si,2
   159 000000E3 AC                      f32:    lodsb           ; Show line contents
   160 000000E4 E82800                          call list_output
   161 000000E7 3C0D                            cmp al,0x0d
   162 000000E9 75F8                            jne f32         ; Jump if it wasn't 0x0d (CR)
   163 000000EB EBEA                            jmp f29
   164                                  f6:
   165 000000ED C3                              ret
   166                                  
   167                                          ; FREE - show bytes available from end of program to RAM_END.
   168                                  free_statement:
   169 000000EE E80600                          call free_bytes
   170 000000F1 E81401                          call output_number
   171 000000F4 E9B702                          jmp new_line
   172                                  
   173                                  free_bytes:
   174 000000F7 E8E902                          call find_program_end
   175 000000FA 8D4502                          lea ax,[di+2]
   176 000000FD BB001E                          mov bx,PROGRAM_TOP
   177 00000100 29C3                            sub bx,ax
   178 00000102 89D8                            mov ax,bx
   179 00000104 C3                              ret
   180                                  
   181                                  print_z:
   182 00000105 AC                              lodsb
   183 00000106 08C0                            or al,al
   184 00000108 74E3                            je f6
   185 0000010A E89D02                          call output
   186 0000010D EBF6                            jmp print_z
   187                                  
   188                                  list_output:
   189 0000010F 3C89                            cmp al,tok_num
   190 00000111 750E                            jne list_kw
   191 00000113 AD                              lodsw
   192 00000114 56                              push si
   193 00000115 E8F000                          call output_number
   194 00000118 5E                              pop si
   195 00000119 B020                            mov al,' '
   196 0000011B E88C02                          call output
   197 0000011E B030                            mov al,'0'
   198 00000120 C3                              ret
   199                                  list_kw:
   200 00000121 3C80                            cmp al,tok_new
   201 00000123 7303E98202                      jb output
   202 00000128 3C8B                            cmp al,tok_chr
   203 0000012A 7600                            jbe list_kw_emit
   204                                  list_kw_emit:
   205 0000012C 56                              push si
   206 0000012D 53                              push bx
   207 0000012E 57                              push di
   208 0000012F 88C3                            mov bl,al
   209 00000131 80EB80                          sub bl,tok_new
   210 00000134 30FF                            xor bh,bh
   211 00000136 BF[A900]                        mov di,kw_table
   212                                  list_seek:
   213 00000139 80FB00                          cmp bl,0
   214 0000013C 740B                            je list_emit
   215                                  list_skip:
   216 0000013E 8A05                            mov al,[di]
   217 00000140 47                              inc di
   218 00000141 A880                            test al,0x80
   219 00000143 74F9                            jz list_skip
   220 00000145 FECB                            dec bl
   221 00000147 EBF0                            jmp list_seek
   222                                  list_emit:
   223 00000149 8A05                            mov al,[di]
   224 0000014B 47                              inc di
   225 0000014C 88C4                            mov ah,al
   226 0000014E 247F                            and al,0x7f
   227 00000150 E85702                          call output
   228 00000153 F6C480                          test ah,0x80
   229 00000156 74F1                            jz list_emit
   230 00000158 B020                            mov al,' '
   231 0000015A E84D02                          call output
   232 0000015D 5F                              pop di
   233 0000015E 5B                              pop bx
   234 0000015F 5E                              pop si
   235 00000160 B030                            mov al,'0'
   236 00000162 C3                              ret
   237                                  
   238                                          ;
   239                                          ; Handle 'input' statement
   240                                          ;
   241                                  input_statement:
   242 00000163 E89000                          call get_variable   ; Get variable address
   243 00000166 50                              push ax             ; Save it
   244 00000167 B03F                            mov al,'?'          ; Prompt
   245 00000169 E80C01                          call input_line     ; Wait for line
   246                                          ;
   247                                          ; Second part of the assignment statement
   248                                          ;
   249                                  assignment:
   250 0000016C E80300                          call expr           ; Process expression
   251 0000016F 5F                              pop di
   252 00000170 AB                              stosw               ; Save onto variable
   253 00000171 C3                              ret
   254                                  
   255                                          ;
   256                                          ; Handle an expression.
   257                                          ; First tier: addition & subtraction.
   258                                          ;
   259                                  expr:
   260 00000172 E81F00                          call expr1          ; Call second tier
   261 00000175 803C2D                  f20:    cmp byte [si],'-'   ; Subtraction operator?
   262 00000178 7411                            je f19              ; Yes, jump
   263 0000017A 803C2B                          cmp byte [si],'+'   ; Addition operator?
   264 0000017D 7403E96BFF                      jne f6              ; No, return
   265 00000182 50                              push ax
   266 00000183 E80D00                          call expr1_2        ; Call second tier
   267 00000186 59                      f15:    pop cx
   268 00000187 01C8                            add ax,cx           ; Addition
   269 00000189 EBEA                            jmp f20             ; Find more operators
   270                                  
   271                                  f19:
   272 0000018B 50                              push ax
   273 0000018C E80400                          call expr1_2        ; Call second tier
   274 0000018F F7D8                            neg ax              ; Negate it (a - b converted to a + -b)
   275 00000191 EBF3                            jmp f15
   276                                  
   277                                          ;
   278                                          ; Handle an expression.
   279                                          ; Second tier: division & multiplication.
   280                                          ;
   281                                  expr1_2:
   282 00000193 46                              inc si              ; Avoid operator
   283                                  expr1:
   284 00000194 E82200                          call expr2          ; Call third tier
   285 00000197 803C2F                  f21:    cmp byte [si],'/'   ; Division operator?
   286 0000019A 7411                            je f23              ; Yes, jump
   287 0000019C 803C2A                          cmp byte [si],'*'   ; Multiplication operator?
   288 0000019F 7403E949FF                      jne f6              ; No, return
   289                                  
   290 000001A4 50                              push ax
   291 000001A5 E81000                          call expr2_2        ; Call third tier
   292 000001A8 59                              pop cx
   293 000001A9 F7E9                            imul cx             ; Multiplication
   294 000001AB EBEA                            jmp f21             ; Find more operators
   295                                  
   296                                  f23:
   297 000001AD 50                              push ax
   298 000001AE E80700                          call expr2_2        ; Call third tier
   299 000001B1 59                              pop cx
   300 000001B2 91                              xchg ax,cx
   301 000001B3 99                              cwd                 ; Expand AX to DX:AX
   302 000001B4 F7F9                            idiv cx             ; Signed division
   303 000001B6 EBDF                            jmp f21             ; Find more operators
   304                                  
   305                                          ;
   306                                          ; Handle an expression.
   307                                          ; Third tier: parentheses, numbers and vars.
   308                                          ;
   309                                  expr2_2:
   310 000001B8 46                              inc si              ; Avoid operator
   311                                  expr2:
   312 000001B9 E84600                          call spaces         ; Jump spaces
   313 000001BC AC                              lodsb               ; Read character
   314 000001BD 3C28                            cmp al,'('          ; Open parenthesis?
   315 000001BF 750B                            jne f24
   316 000001C1 E8AEFF                          call expr           ; Process inner expr.
   317 000001C4 803C29                          cmp byte [si],')'   ; Closing parenthesis?
   318 000001C7 7438                            je spaces_2         ; Yes, avoid spaces
   319 000001C9 E9C1FE                          jmp error           ; No, jump to error
   320                                  
   321 000001CC 3C40                    f24:    cmp al,0x40         ; Variable?
   322 000001CE 7306                            jnc f25             ; Yes, jump
   323 000001D0 4E                              dec si              ; Back one letter...
   324 000001D1 E84900                          call input_number   ; ...to read number
   325 000001D4 EB2C                            jmp spaces
   326                                  
   327 000001D6 3C89                    f25:    cmp al,tok_num
   328 000001D8 7502                            jne f33
   329 000001DA AD                              lodsw
   330 000001DB C3                              ret
   331 000001DC 3C88                    f33:    cmp al,tok_rnd
   332 000001DE 740A                            je f34
   333 000001E0 3C72                            cmp al,0x72
   334 000001E2 750B                            jne f22
   335 000001E4 803C6E                          cmp byte [si],0x6e
   336 000001E7 7506                            jne f22
   337 000001E9 AD                              lodsw               ; Advance SI by 2
   338                                  f34:
   339 000001EA E440                            in al,0x40          ; Read timer counter 0
   340 000001EC B400                            mov ah,0       
   341 000001EE C3                              ret
   342                                  
   343 000001EF E80500                  f22:    call get_variable_2 ; Get variable address
   344 000001F2 93                              xchg ax,bx
   345 000001F3 8B07                            mov ax,[bx]         ; Read
   346 000001F5 C3                              ret                 ; Return
   347                                  
   348                                          ;
   349                                          ; Get variable address.
   350                                          ; Also avoid spaces.
   351                                          ;
   352                                  get_variable:
   353 000001F6 AC                              lodsb               ; Read source
   354                                  get_variable_2:
   355 000001F7 241F                            and al,0x1f         ; 0x61-0x7a -> 0x01-0x1a
   356 000001F9 00C0                            add al,al           ; x 2 (each variable = word)
   357 000001FB 30E4                            xor ah,ah
   358 000001FD 05[0010]                        add ax,vars         ; Setup full address
   359 00000200 4E                              dec si
   360                                          ;
   361                                          ; Avoid spaces after current character
   362                                          ;
   363                                  spaces_2:
   364 00000201 46                              inc si
   365                                          ;
   366                                          ; Avoid spaces
   367                                          ; The interpreter depends on this routine not modifying AX
   368                                          ;
   369                                  spaces:
   370 00000202 803C20                          cmp byte [si],' '   ; Space found?
   371 00000205 74FA                            je spaces_2         ; Yes, move one character ahead.
   372 00000207 C3                              ret                 ; No, return.
   373                                  
   374                                          ;
   375                                          ; Output unsigned number 
   376                                          ; AX = value
   377                                          ;
   378                                  output_number:
   379                                  f26:
   380 00000208 31D2                            xor dx,dx           ; DX:AX
   381 0000020A B90A00                          mov cx,10           ; Divisor = 10
   382 0000020D F7F1                            div cx              ; Divide
   383 0000020F 09C0                            or ax,ax            ; Nothing at left?
   384 00000211 52                              push dx
   385 00000212 7403                            je f8               ; No, jump
   386 00000214 E8F1FF                          call f26            ; Yes, output left side
   387 00000217 58                      f8:     pop ax
   388 00000218 0430                            add al,'0'          ; Output remainder as...
   389 0000021A E98D01                          jmp output          ; ...ASCII digit
   390                                  
   391                                          ;
   392                                          ; Read number in input.
   393                                          ; AX = result
   394                                          ;
   395                                  input_number:
   396 0000021D 31DB                            xor bx,bx           ; BX = 0
   397 0000021F AC                      f11:    lodsb               ; Read source
   398 00000220 2C30                            sub al,'0'
   399 00000222 3C0A                            cmp al,10           ; Digit valid?
   400 00000224 98                              cbw
   401 00000225 93                              xchg ax,bx
   402 00000226 7309                            jnc f12             ; No, jump
   403 00000228 B90A00                          mov cx,10           ; Multiply by 10
   404 0000022B F7E1                            mul cx
   405 0000022D 01C3                            add bx,ax           ; Add new digit
   406 0000022F EBEE                            jmp f11             ; Continue
   407                                  
   408 00000231 4E                      f12:    dec si              ; SI points to first non-digit
   409 00000232 C3                              ret
   410                                  
   411                                          ;
   412                                          ; Handle 'system' statement
   413                                          ;
   414                                  system_statement:
   415 00000233 CD20                            int 0x20
   416                                  
   417                                          ;
   418                                          ; Handle 'goto' statement
   419                                          ;
   420                                  goto_statement:
   421 00000235 E83AFF                          call expr           ; Handle expression
   422 00000238 E88201                          call find_line
   423 0000023B 3905                            cmp word [di],ax
   424 0000023D 7403E9ABFE                      jne f6
   425 00000242 803E[3410]00                    cmp byte [running],0
   426 00000247 7408                            je run_from_di
   427 00000249 893E[3610]                      mov [run_next],di
   428 0000024D C3                              ret
   429                                  
   430                                          ;
   431                                          ; Handle 'run' statement
   432                                          ; (equivalent to 'goto 0')
   433                                          ;
   434                                  run_statement:
   435 0000024E BF[7C10]                        mov di,program
   436                                  run_from_di:
   437 00000251 C606[3410]01                    mov byte [running],1
   438                                  run_loop:
   439 00000256 833D00                          cmp word [di],0
   440 00000259 7417                            je run_end
   441 0000025B 89FE                            mov si,di
   442 0000025D E87401                          call next_line_ptr
   443 00000260 8936[3610]                      mov [run_next],si
   444 00000264 89FE                            mov si,di
   445 00000266 83C602                          add si,2
   446 00000269 E8CEFD                          call statement
   447 0000026C 8B3E[3610]                      mov di,[run_next]
   448 00000270 EBE4                            jmp run_loop
   449                                  run_end:
   450 00000272 C606[3410]00                    mov byte [running],0
   451 00000277 C3                              ret
   452                                  
   453                                          ;------------------------------------------------------------
   454                                          ; INPUT_LINE
   455                                          ; Function : Read edited input line with backspace support.
   456                                          ; Inputs   : AL = prompt character.
   457                                          ; Outputs  : LINE[] = text + CR, SI = LINE.
   458                                          ; Clobbers : AX,CX,DI.
   459                                          ;------------------------------------------------------------
   460                                  input_line:
   461 00000278 E82F01                          call output
   462 0000027B BE[3810]                        mov si,line
   463 0000027E 56                              push si
   464 0000027F 5F                              pop di          ; Target for writing line
   465 00000280 31C9                            xor cx,cx       ; Number of chars in buffer
   466 00000282 E82001                  f1:     call input_key  ; Read keyboard
   467 00000285 3C08                            cmp al,0x08     ; Backspace?
   468 00000287 7517                            jne f1_not_bs
   469 00000289 09C9                            or cx,cx
   470 0000028B 74F5                            je f1
   471 0000028D 4F                              dec di
   472 0000028E 49                              dec cx
   473 0000028F B008                            mov al,0x08
   474 00000291 E81601                          call output
   475 00000294 B020                            mov al,' '
   476 00000296 E81101                          call output
   477 00000299 B008                            mov al,0x08
   478 0000029B E80C01                          call output
   479 0000029E EBE2                            jmp f1
   480                                  f1_not_bs:
   481 000002A0 3C0D                            cmp al,0x0d     ; CR pressed?
   482 000002A2 740C                            je f1_store_cr
   483 000002A4 83F920                          cmp cx,32       ; Max chars reached?
   484 000002A7 73D9                            jae f1          ; Ignore extra chars
   485 000002A9 E8FE00                          call output
   486 000002AC AA                              stosb
   487 000002AD 41                              inc cx
   488 000002AE EBD2                            jmp f1
   489                                  f1_store_cr:
   490 000002B0 E8F700                          call output
   491 000002B3 AA                              stosb
   492 000002B4 C3                              ret             ; Yes, return
   493                                          ;------------------------------------------------------------
   494                                          ; TOKENIZE_LINE
   495                                          ; Function : Tokenize BASIC source line into LINE_TOK buffer.
   496                                          ; Inputs   : SI = source text after parsed line number.
   497                                          ; Outputs  : SI = LINE_TOK, tokenized line ends with CR.
   498                                          ; Clobbers : AX,BX,CX,DI,DL.
   499                                          ;------------------------------------------------------------
   500                                  tokenize_line:
   501 000002B5 E84AFF                          call spaces
   502 000002B8 BF[5A10]                        mov di,line_tok
   503                                  tok_scan:
   504 000002BB AC                              lodsb
   505 000002BC 3C0D                            cmp al,0x0d
   506 000002BE 744D                            je tok_done
   507 000002C0 3C22                            cmp al,'"'
   508 000002C2 743E                            je tok_string
   509 000002C4 3C2D                            cmp al,'-'
   510 000002C6 7515                            jne tok_not_minus
   511 000002C8 803C30                          cmp byte [si],'0'
   512 000002CB 7222                            jb tok_keyword
   513 000002CD 803C39                          cmp byte [si],'9'
   514 000002D0 771D                            ja tok_keyword
   515 000002D2 B089                            mov al,tok_num
   516 000002D4 AA                              stosb
   517 000002D5 E845FF                          call input_number
   518 000002D8 F7D8                            neg ax
   519 000002DA AB                              stosw
   520 000002DB EBDE                            jmp tok_scan
   521                                  tok_not_minus:
   522 000002DD 3C30                            cmp al,'0'
   523 000002DF 720E                            jb tok_keyword
   524 000002E1 3C39                            cmp al,'9'
   525 000002E3 770A                            ja tok_keyword
   526 000002E5 4E                              dec si
   527 000002E6 B089                            mov al,tok_num
   528 000002E8 AA                              stosb
