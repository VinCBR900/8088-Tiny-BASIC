   624 0000036C 3C22                            cmp al,'"'      ; Double quotes?
   625 0000036E 742F                            je f18          ; Yes, jump
   626 00000370 E83700                          call output     ; Output character
   627 00000373 3C0D                            cmp al,0x0d     ; 
   628 00000375 75F4                            jne f9          ; Jump if not finished with 0x0d (CR)
   629 00000377 C3                              ret             ; Return
