   680                                          ;------------------------------------------------------------
   681                                          ; FIND_LINE
   682                                          ; Function : Find first packed line >= AX.
   683                                          ; Inputs   : AX = line number.
   684                                          ; Outputs  : DI = line pointer or end marker.
   685                                          ; Clobbers : BX,SI.
   686                                          ;------------------------------------------------------------
   687                                  find_line:
   688 000003BD BF[7C10]                        mov di,program
   689                                  find_line_1:
   690 000003C0 8B1D                            mov bx,[di]
   691 000003C2 09DB                            or bx,bx
   692 000003C4 740D                            je find_line_done
   693 000003C6 39C3                            cmp bx,ax
   694 000003C8 7309                            jae find_line_done
   695 000003CA 50                              push ax
   696 000003CB E80600                          call next_line_ptr
   697 000003CE 89F7                            mov di,si
   698 000003D0 58                              pop ax
   699 000003D1 EBED                            jmp find_line_1
   700                                  find_line_done:
   701 000003D3 C3                              ret
   702                                  
   703                                          ; Compute SI=next line pointer from DI=current line.
   704                                  next_line_ptr:
   705 000003D4 89FE                            mov si,di
   706 000003D6 83C602                          add si,2
   707                                  next_line_ptr_1:
   708 000003D9 803C0D                          cmp byte [si],0x0d
   709 000003DC 7403                            je next_line_ptr_2
   710 000003DE 46                              inc si
   711 000003DF EBF8                            jmp next_line_ptr_1
   712                                  next_line_ptr_2:
   713 000003E1 46                              inc si
   714 000003E2 C3                              ret
   715                                  
   716                                          ; Find program end marker (word zero)
   717                                  find_program_end:
   718 000003E3 BF[7C10]                        mov di,program
   719                                  find_program_end_1:
   720 000003E6 8B05                            mov ax,[di]
   721 000003E8 09C0                            or ax,ax
   722 000003EA 7407                            je find_program_end_done
   723 000003EC E8E5FF                          call next_line_ptr
   724 000003EF 89F7                            mov di,si
   725 000003F1 EBF3                            jmp find_program_end_1
   726                                  find_program_end_done:
   727 000003F3 C3                              ret
