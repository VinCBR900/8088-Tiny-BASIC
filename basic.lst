   612                                          ;
   613                                          ; Handle "print" statement
   614                                          ;
   615                                  print_statement:
   616 00000362 AC                              lodsb           ; Read source
   617 00000363 3C0D                            cmp al,0x0d     ; End of line?
   618 00000365 7447                            je new_line     ; Yes, generate new line and return
   619 00000367 3C22                            cmp al,'"'      ; Double quotes?
   620 00000369 750D                            jne f7          ; No, jump
   621                                  print_2:
   622                                  f9:
